# ═══════════════════════════════════════════════════════════════════════════════
# ChatBot SaaS — Production Environment Variables
# Copy this file to .env and fill in every value before deploying.
# Generate secrets with: python3 -c "import secrets; print(secrets.token_hex(32))"
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=chatbot_db
DATABASE_URL=postgresql+asyncpg://chatbot:CHANGE_ME_strong_password_here@db:5432/chatbot_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_random_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth — from Google Cloud Console → APIs & Services → Credentials
# Authorized JavaScript origins: https://yourdomain.com
# Authorized redirect URIs: not needed for credential flow
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Frontend (build-time) ──────────────────────────────────────────────────────
# These are baked into the Next.js build — set them before `docker compose build`
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── AI — set at least one ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...
GROK_API_KEY=

# ── Billing: Stripe (International) ──────────────────────────────────────────
# Use sk_live_... / pk_live_... in production (not sk_test_...)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── Billing: Razorpay (India) ─────────────────────────────────────────────────
# Use rzp_live_... in production (not rzp_test_...)
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME
RAZORPAY_STARTER_PLAN_ID=plan_...
RAZORPAY_GROWTH_PLAN_ID=plan_...
RAZORPAY_ENTERPRISE_PLAN_ID=plan_...

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the dashboard
CORS_ORIGINS=https://yourdomain.com

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ── Platform Admin ────────────────────────────────────────────────────────────
# Powers the in-dashboard help chatbot (bottom-left teal bubble)
PLATFORM_ADMIN_EMAIL=admin@yourdomain.com
PLATFORM_ADMIN_PASSWORD=CHANGE_ME_strong_password_here
